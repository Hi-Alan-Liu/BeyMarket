# ============================================================
#  BeyMarket 環境變數範本 — 複製為 .env 後填入
#  cp .env.example .env
# ============================================================

# --- 資料庫（PostgreSQL）---
# 本機開發：npm run db:up 會用 docker-compose 啟動符合此字串的 Postgres
# 正式環境：換成 Zeabur / Neon / Supabase 提供的連線字串
DATABASE_URL="postgresql://beymarket:beymarket@localhost:5432/beymarket?schema=public"

# --- Auth.js（NextAuth v5）---
# 產生新的金鑰：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="請填入隨機金鑰"
AUTH_TRUST_HOST="true"

# --- 第三方登入（之後啟用時填入）---
# AUTH_DISCORD_ID=""
# AUTH_DISCORD_SECRET=""
# AUTH_LINE_ID=""
# AUTH_LINE_SECRET=""
